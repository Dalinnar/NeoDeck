    "Execute python code": {
      "command": "/exec {code_type} {selected_option}",
     "inputs": [
  {
    "TYPE": "select",
    "name": "code_type",
    "options": ["uploaded_file", "file_path", "single_line"]
  },
  {
    "TYPE": "input file", 
    "name": "selected_option",
    "file_type": ".py",
    "dependant_on": "uploaded_file"
  },
  {
    "TYPE": "input text",
    "name": "selected_option",
    "dependant_on": "file_path"
  },
  {
    "TYPE": "input text",
    "name": "selected_option",
    "dependant_on": "single_line"
  }
],
      "style": {
        "image": "execpython.png",
        "image_size": "70%"
      }
    },
    "Execute batch code": {
      "command": "/batch {batch_code}",
      "inputs": [
        {
          "TYPE":"textarea",
          "name": "batch_code"
        }
