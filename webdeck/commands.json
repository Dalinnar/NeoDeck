  "Text": {
    "Press a key": {
      "command": "/key {key}",
      "inputs": [
        {
          "TYPE": "input text",
          "name": "key",
          "size":"1"
        }
      ],
      "style": {
        "image": "key.png",
        "image_size": "75%"
      }
    },
    "Write text": {
      "command": "/write {text}",
      "inputs": [
        {
          "TYPE": "textarea",
          "name": "text",
          "placeholder": "your bash code here..."
        }
      ],
      "style": {
        "image": "write.png",
        "image_size": "75%"
      }
    },
    "Write text and press Enter": {
      "command": "/writeandsend {text}",
      "inputs": [
        {
          "TYPE": "textarea",
          "name":"text",
          "placeholder": "put your text here..."
        }
      ],
      "style": {
        "image": "write.png",
