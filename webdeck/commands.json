  "System": {
    "Volume": {
      "TYPE": "multiple",
      "commands": [
        {
          "command": "!volume",
          "inputs": [],
          "min":"0",
          "max":"100"
        },
        {
          "command": "/volume +{volume-number}",
          "inputs": [
            {
              "TYPE": "input number",
              "name": "volume-number",
              "min": "0",
              "max": "100",
              "placeholder": "1"
            }
            
          ],
          "style": {
            "image": "volume-up.svg",
            "image_size": "75%"
          }
        },
        {
          "command": "/volume -{volume-number}",
          "inputs": [
            {
              "TYPE": "input number",
              "name": "volume-number",
              "min": "0",
              "max": "100",
              "placeholder": "1"
            }
          ],
          "style": {
            "image": "volume-down.svg",
            "image_size": "75%"
          }
        },
        {
          "command": "/volume set{volume-number}",
          "inputs": [
            {
              "TYPE": "input number",
              "name": "volume-number",
              "min": "0",
              "max": "100",
              "placeholder": "1"
            }
          ],
          "style": {
            "image": "sound.png",
            "image_size": "75%"
          }
        },
        {
          "command": "/soundcontrol mute",
          "inputs": [],
          "style": {
            "image": "volume-mute.svg",
            "image_size": "75%"
          }
        }
      ]
    },
