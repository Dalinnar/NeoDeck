<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>plugins Store</title>

    <link rel="stylesheet" href="/static/css/plugins.css">
    <script src="/static/js/default_functions.js"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">

</head>

<body>
    <div class=""></div>
    <div class="plugin-store">
        <div class="plugin-grid" id="plugin-grid"></div>
    </div>

<script>
const domain = "http://localhost/plugins"; // base fija de los plugins

fetch(`${domain}/manifest.json`)
  .then(response => {
    if (!response.ok) throw new Error("Error al obtener el JSON");
    return response.json();
  })
  .then(plugins => {   // AHORA plugins ES LA LISTA DIRECTA
    const grid = document.getElementById("plugin-grid");

    plugins.forEach(plugin => {
        const pluginDiv = document.createElement("div");
        pluginDiv.classList.add("plugin-item");
        pluginDiv.style.cursor = "pointer";

        // Navegar al plugin
        pluginDiv.addEventListener("click", () => {
            window.location.href = `/plugin/${plugin.slug}`;
        });

        // Icono
        const icon = document.createElement("img");
        icon.src = `${domain}/${plugin.slug}/icon.jpg`;
        icon.alt = plugin.name;
        icon.classList.add("plugin-icon");

        // Nombre
        const name = document.createElement("h3");
        name.textContent = plugin.name;
        name.classList.add("plugin-name");

        // Descripción
        const desc = document.createElement("p");
        desc.textContent = plugin.description;
        desc.classList.add("plugin-desc");

        // Versión y autor
        const meta = document.createElement("small");
        const authors = Array.isArray(plugin.author) ? plugin.author.join(", ") : plugin.author;
        meta.textContent = `v${plugin.version} • ${authors}`;
        meta.classList.add("plugin-meta");

        // Agregar elementos al DIV ANTES del botón
        pluginDiv.appendChild(icon);
        pluginDiv.appendChild(name);
        pluginDiv.appendChild(desc);
        pluginDiv.appendChild(meta);

        // Botón al repo (si existe)
        if (plugin.repository) {
            const repoBtn = document.createElement("button");
            repoBtn.textContent = "Go to Repository";
            repoBtn.classList.add("install-btn");
            repoBtn.style.marginTop = "8px";

            repoBtn.addEventListener("click", e => {
                e.stopPropagation();
                window.open(plugin.repository, "_blank");
            });

            pluginDiv.appendChild(repoBtn);
        }

        // Poner todo en el grid
        grid.appendChild(pluginDiv);
    });
  })
  .catch(error => {
    console.error("Error:", error);
  });
</script>
</body>

</html>