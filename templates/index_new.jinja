<html>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="static\icons\icon.ico" />
  <title>Neodeck</title>


  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet">
  <script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
  <script src="/static/js/grid-manager.js"></script>

  <script src="/static/js/utils.js"></script>
  <script src="/static/js/input_factory.js"></script>
  <script src="/static/js/image_gallery.js"></script>
  <script src="/static/js/button_ui.js"></script>
  <script src="/static/js/multiaction_shared.js"></script>
  <script src="/static/js/button_builder.js"></script>
  <script src="/static/js/button_editor.js"></script>
  <script src="/static/js/button_generator.js"></script>

  <script src="/static/js/default_functions.js"></script>
  <script defer src="/static/js/folderConfig.js"></script>
  <script defer src="/static/js/SelectionManager.js"></script>

  {% for script in context["temp_scripts"] %}
  <script src="/temp/{{script}}"></script>
  {% endfor %}
  <link rel="stylesheet" href="/static/css/deck.css">
</head>

<body>
  <div id="pages-container" class="hidden"></div>
  <div class="main-container">
    <div class="buttons-container"></div>
    <div class="menuContainer hidden" id="menuContainer">
      <div class="QuickMenu" id="category_commands">
        <a href="/settings" class="quickmenu_icon" title="settings">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-linecap="round" stroke-linejoin="round" width="20" height="20" stroke-width="1">
            <path
              d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z">
            </path>
            <path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path>
          </svg>
        </a>

        <a href="/plugins" class="quickmenu_icon" title="plugins">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-linecap="round" stroke-linejoin="round" width="20" height="20" stroke-width="1">
            <path d="M10 14a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
            <path
              d="M5.001 8h13.999a2 2 0 0 1 1.977 2.304l-1.255 7.152a3 3 0 0 1 -2.966 2.544h-9.512a3 3 0 0 1 -2.965 -2.544l-1.255 -7.152a2 2 0 0 1 1.977 -2.304z">
            </path>
            <path d="M17 10l-2 -6"></path>
            <path d="M7 10l2 -6"></path>
          </svg>
        </a>
      </div>
    </div>

    <script>
      window.isUsingScrollPad = false;  // MUST exist before touch listeners are attached
    </script>
    <script>
      window.buttonData = {};
      window.folder_data = {{ context["deck_folder"] | tojson | safe }};
      window.folder_name = "{{ context['folder_name'] }}";
      window.image_list = {{ context["image_list"] | tojson | safe }};
      window.pages = {{ context["pages"] | tojson | safe }};

      const translations = {{ context["text"] | tojson | safe }};

      document.addEventListener("DOMContentLoaded", function () {
        const initialPage = JSON.parse('{{ context["deck_folder"] | tojson | safe }}');
        updateGrid(initialPage);

        const commands = JSON.parse('{{ context["commands"] | tojson | safe }}');
        set_menu_commands(commands);
      });

      function updateGrid(pageData) {
        gridManager.updateGrid(pageData);
      }
    </script>


    <!-- ============================================================
  2. MENU — Build, render, search
  Responsible for constructing the sidebar menu from JSON data,
  rendering category/subcategory trees, and filtering via search.
============================================================ -->
    <script defer>
      // --- Helpers ---

      function clean(str) {
        return str.replace(/ /g, "_").replace("'", "").replace(/[{}]/g, "").toLowerCase();
      }

      function getTranslation(key) {
        return translations[key] ?? key;
      }

      // --- Entry point ---

      function set_menu_commands(jsonData) {
        const container = document.getElementById("menuContainer");

        const search = createSearchInput();
        container.appendChild(search);

        Object.entries(jsonData).forEach(([category, data]) => {
          container.appendChild(createCategory(category, data));
        });
      }

      // --- Builders ---

      function createSearchInput() {
        const search = document.createElement("input");
        search.placeholder = getTranslation("SEARCH_COMMANDS");
        search.addEventListener("input", (e) => search_commands(e.target.value));
        return search;
      }

      function createCategory(category, data) {
        const _category = clean(category).toUpperCase();
        const categoryDiv = document.createElement("div");
        categoryDiv.id = `category_${_category}`;

        const categoryName = getTranslation(`${_category}_CATEGORY_NAME`) || category;
        categoryDiv.appendChild(createTitleBar(categoryName, categoryDiv));

        const contentContainer = document.createElement("div");
        contentContainer.id = `container_${_category}`;
        contentContainer.classList.add("container", "hidden");
        categoryDiv.appendChild(contentContainer);

        const buttonsContainer = document.createElement("div");
        buttonsContainer.classList.add("buttons_container");
        contentContainer.appendChild(buttonsContainer);

        const subcategoriesContainer = document.createElement("div");
        subcategoriesContainer.classList.add("subcategories_container");
        contentContainer.appendChild(subcategoriesContainer);

        Object.entries(data).forEach(([name, subdata]) => {
          if (subdata.TYPE === "multiple") {
            subcategoriesContainer.appendChild(createSubcategory(category, name, subdata));
          } else {
            addButton(buttonsContainer, name, subdata, _category);
          }
        });

        return categoryDiv;
      }

      function createSubcategory(category, name, subdata) {
        const _category = clean(category).toUpperCase();
        const _subcategory = `${_category}_${clean(name)}`;
        const subcategoryName = getTranslation(`${_subcategory}__category_name`) || name;

        const subcategoryDiv = document.createElement("div");
        subcategoryDiv.appendChild(createTitleBar(subcategoryName, subcategoryDiv));

        const contentContainer = document.createElement("div");
        contentContainer.classList.add("container", "hidden");
        subcategoryDiv.appendChild(contentContainer);

        const buttonsContainer = document.createElement("div");
        buttonsContainer.classList.add("buttons_container");
        contentContainer.appendChild(buttonsContainer);

        Object.entries(subdata.commands || {}).forEach(([commandName, buttonData]) => {
          populateInputLabels(buttonData, _subcategory, commandName);
          addButton(buttonsContainer, commandName, buttonData, _category, _subcategory);
        });

        return subcategoryDiv;
      }

      function createTitleBar(title, toggleTarget) {
        const container = document.createElement("div");
        container.classList.add("title_container");
        container.onclick = () => {
          toggleCategory(toggleTarget);
          container.classList.toggle("open");
        };

        const icon = document.createElement("img");
        icon.src = "static/img/menu_icon_white.png";
        icon.style.cssText = "width: 30px; aspect-ratio: 1;";

        const heading = document.createElement(title.level === 2 ? "h2" : "h3");
        heading.textContent = title;

        container.appendChild(icon);
        container.appendChild(heading);
        return container;
      }

      function toggleCategory(menu) {
        const container = menu.querySelector(".container");
        container.classList.toggle("hidden");
      }

      function populateInputLabels(buttonData, category, commandName) {
        buttonData.inputs?.forEach((input, index) => {
          input.label = getTranslation(`${category}_${clean(commandName)}_input${index}`);
        });
      }

      function addButton(parentElement, name, data, categ = "", subcateg = "") {
        const div = document.createElement("div");
        div.classList.add("button_opt");

        if (data.image) {
          const img = document.createElement("img");
          img.src = data.image;
          div.appendChild(img);
        }

        const cleanName = clean(name);
        const query = subcateg
          ? `${categ}_${clean(subcateg.replace(/^.*?_/, ""))}_${cleanName}__btn_name`
          : `${categ}_${cleanName}__btn_name`;

        div.innerText = getTranslation(query);
        data.ButtonTitle = getTranslation(query);
        div.id = query;
        window.buttonData[div.id] = data;

        div.draggable = true;
        parentElement.appendChild(div);
      }

      // --- Search / filter ---

      function search_commands(search) {
        const containers = document.querySelectorAll("#menuContainer .container");
        const categories = document.querySelectorAll("#menuContainer [id^='category_']");
        const query = search.trim().toLowerCase();

        if (!query) {
          categories.forEach(category => category.classList.remove("hidden"));
          containers.forEach(container => {
            container.classList.add("hidden");
            container.querySelectorAll(".button_opt").forEach(button => button.classList.remove("hidden"));
          });
          return;
        }

        const matchingCategories = new Set();
        const matchingContainers = new Set();

        categories.forEach(category => {
          const categoryName = category.textContent.toLowerCase();
          const categoryId = category.id;
          const containerId = categoryId.replace("category_", "container_");

          if (categoryName.includes(query)) {
            matchingCategories.add(categoryId);
            matchingContainers.add(containerId);
          }
        });

        containers.forEach(container => {
          const containerId = container.id;
          const categoryId = containerId.replace("container_", "category_");
          const buttons = container.querySelectorAll(".button_opt");
          let hasButtonMatch = false;

          buttons.forEach(button => {
            const buttonMatches = button.textContent.toLowerCase().includes(query);
            button.classList.toggle("hidden", !buttonMatches);
            if (buttonMatches) {
              hasButtonMatch = true;
              matchingCategories.add(categoryId);
              matchingContainers.add(containerId);
            }
          });

          if (matchingCategories.has(categoryId) && !hasButtonMatch) {
            buttons.forEach(button => button.classList.remove("hidden"));
          }
        });

        categories.forEach(category => {
          category.classList.toggle("hidden", !matchingCategories.has(category.id));
        });

        containers.forEach(container => {
          container.classList.toggle("hidden", !matchingContainers.has(container.id));
        });
      }
    </script>


    <!-- ============================================================
  3. BUTTON EDITION — Toggle edit mode, add/remove overlay actions
  Handles the edit/delete overlays on grid buttons and the
  open/close logic for the menu panel (keyboard + touch + click).
============================================================ -->
    <script>
      let startX = 0;
      window.menu_open = false;

      // --- Menu panel open/close ---

      function toggleMenu() {
        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        if (isMobile) return;

        window.menu_open = !window.menu_open;
        const menu = document.querySelector(".menuContainer");
        const pages_container = document.getElementById("pages-container");

        menu.classList.toggle("hidden");
        pages_container.classList.toggle("hidden");
        toggle_buttons_edition();
      }

      // Keyboard shortcut: Q
      document.addEventListener("keydown", function (event) {
        const isInputFocused =
          document.activeElement.tagName.toLowerCase() === "input" ||
          document.activeElement.tagName.toLowerCase() === "textarea";

        if (!isInputFocused && event.key.toLowerCase() === "q") {
          toggleMenu();
        }
      });

      // Touch swipe (mobile)
      document.addEventListener("touchstart", function (event) {
        if (window.isUsingScrollPad) return;
        startX = event.touches[0].clientX;
      });

      document.addEventListener("touchend", function (event) {
        if (window.isUsingScrollPad) return;
        const endX = event.changedTouches[0].clientX;
        if (Math.abs(startX - endX) > 50) toggleMenu();
      });

      // --- Edit/delete overlays on grid buttons ---

      function toggle_buttons_edition(override = false) {
        const buttons = document.querySelectorAll(".button_div");
        const menu = document.querySelector(".menuContainer");
        const isMenuVisible = menu.classList.contains("hidden") || override;

        buttons.forEach((button) => {
          const existingSvg = button.querySelector("svg.delete-btn");
          const existingEdit = button.querySelector("svg.edit-btn");

          if (isMenuVisible) {
            existingSvg?.remove();
            existingEdit?.remove();
          } else {
            if (!existingSvg) {
              button.appendChild(createDeleteOverlay(button));
            }
            if (!existingEdit) {
              button.appendChild(createEditOverlay(button));
            }
          }

          // Draggable only while in edit mode
          if (!isMenuVisible) {
            button.setAttribute("draggable", "true");
          } else {
            button.removeAttribute("draggable");
          }
        });
      }

      function createDeleteOverlay(button) {
        const svg = document.createElement("svg");
        svg.classList.add("delete-btn");
        svg.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
           fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>`;
        Object.assign(svg.style, {
          position: "absolute", top: "5%", right: "5%",
          cursor: "pointer", zIndex: 3, stroke: "red",
          padding: "1%", backgroundColor: "#55555555", borderRadius: "50%",
        });
        svg.addEventListener("click", (event) => {
          event.stopPropagation();
          const [row, col] = button.style.gridArea.split(" / ");
          if (confirm(getTranslation("delete_button_confirm"))) {
            remove_button_from_grid(row, col);
          }
        });
        return svg;
      }

      function createEditOverlay(button) {
        const editSvg = document.createElement("svg");
        editSvg.classList.add("edit-btn");
        editSvg.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
           fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
      </svg>`;
        Object.assign(editSvg.style, {
          position: "absolute", top: "5%", left: "5%",
          cursor: "pointer", zIndex: 3, stroke: "dodgerblue",
          padding: "1%", backgroundColor: "#55555555", borderRadius: "50%",
        });
        editSvg.addEventListener("click", (event) => {
          event.stopPropagation();
          const [row, col] = button.style.gridArea.split(" / ");
          edit_button_in_grid(row, col);
        });
        return editSvg;
      }

      // --- Grid button CRUD ---

      async function remove_button_from_grid(row, col) {
        const folder_data = window.folder_data;
        const folder_name = window.folder_name;

        const buttonIndex = folder_data.buttons.findIndex(
          (button) => button.row == row && button.column == col
        );

        if (buttonIndex !== -1) {
          folder_data.buttons.splice(buttonIndex, 1);
          console.log(`Button at row ${row}, column ${col} removed.`);
          const result = await uploadFolderData(folder_name, folder_data);
          updateGrid(result.folder);
        } else {
          console.log(`No button found at row ${row}, column ${col}.`);
        }
      }

      async function edit_button_in_grid(row, col) {
        const folder_data = window.folder_data;
        const folder_name = window.folder_name;

        // Find the button at this position
        const buttonIndex = folder_data.buttons.findIndex(
          (button) => button.row == row && button.column == col
        );

        if (buttonIndex === -1) {
          console.log(`No button found at row ${row}, column ${col}.`);
          return;
        }

        const savedButton = folder_data.buttons[buttonIndex];

        // Get the original button template from constructor
        const constructor_id = savedButton.constructor;
        if (!constructor_id || !window.buttonData[constructor_id]) {
          alert("Cannot edit this button: constructor not found");
          console.log("Constructor ID:", constructor_id, "Available data:", window.buttonData);

          return;
        }

        const originalButtonData = window.buttonData[constructor_id];

        // Open the dialog in edit mode
        const modal = document.getElementById("button_creator_dialog");

        if (originalButtonData.command == "__multiaction__") {
          modal.show();
          window.dialogopen = true;
          setup_multiaction_edit(originalButtonData, folder_name, folder_data, col, row, savedButton, buttonIndex);
        } else {
          modal.showModal();
          window.dialogopen = true;
          setup_regular_edit(originalButtonData, folder_name, folder_data, col, row, savedButton, buttonIndex);
        }
      }
    </script>


    <!-- ============================================================
  4. DRAG & DROP — Drag menu items onto grid slots
  Handles dragging .button_opt items from the menu panel and
  dropping them onto empty grid cells to place new buttons.
============================================================ -->
    <script>
      function setupDragAndDrop() {
        document.addEventListener("dragover", (e) => e.preventDefault());

        const menuButtons = document.querySelectorAll("#menuContainer .button_opt");
        const deckSlots = document.querySelectorAll(".buttons-container div:empty");
        const validButtonIds = new Set([...menuButtons].map((btn) => btn.id));

        function createDragImage() {
          const dragImage = document.createElement("div");
          Object.assign(dragImage.style, {
            width: "100px", height: "100px", opacity: "0.8",
            backgroundColor: "rgba(0, 0, 0, 0.5)", borderRadius: "8px",
            pointerEvents: "none", position: "absolute", zIndex: "9999",
          });
          document.body.appendChild(dragImage);
          return dragImage;
        }

        menuButtons.forEach((button) => {
          button.addEventListener("dragstart", (e) => {
            const dragImage = createDragImage();
            e.dataTransfer.setDragImage(dragImage, 50, 50);
            e.dataTransfer.setData("text/plain", button.id);
            button.addEventListener("dragend", () => dragImage.remove(), { once: true });
          });
        });

        deckSlots.forEach((slot) => {
          slot.addEventListener("drop", (e) => {
            e.preventDefault();
            const id = e.dataTransfer.getData("text/plain");
            if (!validButtonIds.has(id)) return;

            const buttonData = window.buttonData?.[id];
            if (!buttonData) return;

            const parent = slot.parentNode;
            const parentRect = parent.getBoundingClientRect();
            const slotRect = slot.getBoundingClientRect();

            const getSize = (value) => parseFloat(value.replace("px", "")) || 1;
            const columnWidth = getSize(
              getComputedStyle(parent).getPropertyValue("grid-template-columns").split(" ")[0]
            );
            const rowHeight = getSize(
              getComputedStyle(parent).getPropertyValue("grid-template-rows").split(" ")[0]
            );

            const col = Math.floor((slotRect.left - parentRect.left) / columnWidth) + 1;
            const row = Math.floor((slotRect.top - parentRect.top) / rowHeight) + 1;

            const cleanId = id.replace(/__btn_name$/, "");
            generate_button(buttonData, window.folder_name, window.folder_data, col, row, id);
          });
        });
      }

      window.addEventListener("load", setupDragAndDrop);
    </script>


    <!-- ============================================================
  5. MONITORS — Poll server for live data and update DOM
  Periodically fetches usage/status data and reflects it in any
  element carrying a [data_from] attribute.
============================================================ -->
    <script>
      let isFetching = false;
      const monitorTracks = new Set();

      function Initialize_monitors(track) {
        if (track) monitorTracks.add(track);
        if (isFetching) return;
        isFetching = true;
        fetch_monitors();
      }

      function fetch_monitors() {
        fetch("/monitors", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ track: [...monitorTracks] }),
        })
          .then((response) => response.json())
          .then((data) => { window.usage_dict = data; })
          .catch(() => console.error("Error fetching usage data"))
          .finally(() => {
            update_monitors();
            setTimeout(fetch_monitors, 5000);
          });
      }

      function update_monitors() {
        document.querySelectorAll("[data_from]").forEach((monitor) => {
          const dataFrom = monitor.getAttribute("data_from");
          const value = dataFrom.split(".").reduce((obj, key) => obj && obj[key], window);
          if (value !== undefined) monitor.innerHTML = value;
        });
      }
    </script>

</body>

</html>