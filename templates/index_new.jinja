<html>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="static\icons\icon.ico" />
  <title>WebDeck</title>


  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet">
  <script src="/static/js/default_functions.js"></script>
  <script src="/static/js/button_generator.js"></script>
  <script defer src="/static/js/folderConfig.js"></script>
  <script defer src="/static/js/SelectionManager.js"></script>
  <link rel="stylesheet" href="/static/css/deck.css">
</head>

<body>

  <div id="pages-container" class="hidden"></div>
  <div class="main-container">
    <div class="buttons-container"></div>
    <div class="menuContainer hidden" id="menuContainer">
      <div class="QuickMenu" id="category_commands">
        <a href="/settings" class="quickmenu_icon" title="settings">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-linecap="round" stroke-linejoin="round" width="20" height="20" stroke-width="1">
            <path
              d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z">
            </path>
            <path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path>
          </svg>
        </a>

        <a href="/plugins" class="quickmenu_icon" title="plugins">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-linecap="round" stroke-linejoin="round" width="20" height="20" stroke-width="1">
            <path d="M10 14a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"></path>
            <path
              d="M5.001 8h13.999a2 2 0 0 1 1.977 2.304l-1.255 7.152a3 3 0 0 1 -2.966 2.544h-9.512a3 3 0 0 1 -2.965 -2.544l-1.255 -7.152a2 2 0 0 1 1.977 -2.304z">
            </path>
            <path d="M17 10l-2 -6"></path>
            <path d="M7 10l2 -6"></path>
          </svg>
        </a>
      </div>
    </div>
    <script>
      //add all the data to the grid
      window.buttonData = {}
      window.folder_data = {{ context["deck_folder"] | tojson | safe }}
      window.folder_name = "{{ context['folder_name'] }}"
      window.image_list = {{ context["image_list"] | tojson | safe }}
      window.pages = {{ context["pages"] | tojson | safe }}
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {

        // Cargar la página inicial desde el contexto
        const initialPage = JSON.parse('{{ context["deck_folder"] | tojson | safe}}');
        updateGrid(initialPage);

        const commands = JSON.parse('{{ context["commands"] | tojson | safe}}');

        set_menu_commands(commands);
      });

      function updateGrid(pageData) {

        main_container = document.querySelector(".main-container");
        //the background based on pageData.background
        if (pageData.background) {
          main_container.style.background = pageData.background;
        }
        if (pageData.background_img) {
          main_container.style.backgroundImage = `url(${pageData.background_img})`;
          //no repeat and cover
          main_container.style.backgroundRepeat = "no-repeat";
          main_container.style.backgroundSize = "cover";
          main_container.style.backgroundPosition = "center";
        }


        const container = document.querySelector(".buttons-container");
        if (!container) return;
        container.innerHTML = "";

        const rows = Number(pageData.rows);
        const cols = Number(pageData.columns);

        if (!rows || !cols) return;

        // Configurar el grid
        container.style.display = "grid";
        container.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
        container.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        container.style.aspectRatio = `${cols} / ${rows}`;

        // Usar un Set para rastrear posiciones ocupadas
        const occupiedPositions = new Set();

        pageData.buttons.forEach((button, index) => {

          if (button.custom_generator) {
            eval(button.custom_generator);
            return;
          }
          const button_div = document.createElement("div");
          button_div.classList.add("button_div");
          button_div.id = "button_" + index;

          button_div.style.backgroundColor = button.background_color;
          button_div.style.color = button.text_color;

          button_div.style.gridArea = `${button.row} / ${button.column} / ${button.endrow ?? button.row} / ${button.endcolumn ?? button.column}`;
          if (button.image) {
            const img = document.createElement("img");
            Object.assign(img, {
              src: button.image,
              style: `width: ${button.image_size}%; height: ${button.image_size}%;`,
              draggable: false
            });
            button_div.appendChild(img);
          }

          if (button.image) {
            const img = document.createElement("img");
            img.src = button.image;
            //make the image not draggable
            img.draggable = false;
            img.alt = "Button Image";
            img.style.width = `${button.image_size}%`;
            img.style.height = `${button.image_size}%`;
            button_div.appendChild(img);

            //if button image size is 100% then remove background color
            if (button.image_size == 100) {
              button_div.style.backgroundColor = "transparent";
            }
          }

          if (button.btn_text) {
            const btn_text = document.createElement("h3");
            btn_text.innerText = button.btn_text;
            btn_text.style.zIndex = 2;
            button_div.appendChild(btn_text);
          }

          if (button.command) {
            button_div.addEventListener("click", () => {
              //if the command starts with "$" its an eval
              if (button.command.startsWith("$")) {
                eval(button.command.slice(1));
              }
              //if the command starts with / its a command
              if (button.command.startsWith("/")) {
                send_data(button.command);
              }

            })
            //if the commands is "#monitor"
            if (button.command === "#monitor") {
              console.log(button.track);
              Initialize_monitors(button.track ?? undefined);
              const monitor = document.createElement("h2");

              monitor.style.zIndex = 2;
              monitor.setAttribute("data_from", button.collect_data_from);

              button_div.appendChild(monitor);
            }
            if (button.command.startsWith("!")) {

              const range = document.createElement("input");
              range.type = "range";
              range.classList.add("slider");
              range.min = button.min;
              range.style.zIndex = 2;
              range.max = button.max;
              button_div.appendChild(range);

              range.addEventListener("change", function () {
                send_data(button.command + " " + range.value);
              });
            }
          }

          container.appendChild(button_div);

          // Marcar la posición como ocupada
          occupiedPositions.add(`${button.row}-${button.column}`);
        });
        // Crear los elementos vacíos SOLO en las posiciones libres
        for (let r = 1; r <= rows; r++) {
          for (let c = 1; c <= cols; c++) {

            const element = document.createElement("div");
            element.style.gridArea = `${r} / ${c}`;
            element.classList.add("grid-item");
            container.appendChild(element);

          }
        }
        setupDragAndDrop();
        toggle_buttons_edition();
      }

    </script>

    <script>
      let startX = 0;
      function toggleMenu() {
        const menu = document.querySelector(".menuContainer");
        const pages_container = document.getElementById("pages-container");

        menu.classList.toggle("hidden");
        pages_container.classList.toggle("hidden");

        toggle_buttons_edition()

      }
      function toggle_buttons_edition(override = false) {
        const buttons = document.querySelectorAll(".button_div");
        const menu = document.querySelector(".menuContainer");
        const isMenuVisible = menu.classList.contains("hidden") || override;

        buttons.forEach((button) => {
          // Si el menú está visible o el override es verdadero, eliminar el SVG si existe
          const existingSvg = button.querySelector("svg");
          if (isMenuVisible && existingSvg) {
            existingSvg.remove(); // Eliminar el SVG
          } else if (!isMenuVisible && !existingSvg) {
            // Si el menú está visible, agregar el SVG si no existe
            const svg = document.createElement("svg");
            svg.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>`;
            svg.style.position = "absolute";
            svg.style.top = "5%";
            svg.style.right = "5%";
            svg.style.cursor = "pointer";
            svg.style.zIndex = 3;
            svg.style.stroke = "red";
            svg.style.padding = "1%";
            svg.style.backgroundColor = "#55555555";
            svg.style.borderRadius = "50%";

            // Agregar el evento de click al SVG para removerlo
            svg.addEventListener("click", (event) => {
              const button_grid_area = button.style.gridArea;
              const [row, col] = button_grid_area.split(" / ");

              if (confirm("Are you sure you want to delete this button?")) {
                remove_button_from_grid(row, col);
              }
              event.stopPropagation(); // Detener la propagación del evento
            });

            button.appendChild(svg); // Añadir el SVG al botón
          }

          // Hacer que el botón sea arrastrable si el menú está visible
          if (!isMenuVisible) {
            button.setAttribute("draggable", "true");
          } else {
            button.removeAttribute("draggable");
          }
        });
      }
      document.addEventListener("keydown", function (event) {
        // Verificar si el foco está en un input o elemento similar
        const isInputFocused = document.activeElement.tagName.toLowerCase() === "input" ||
          document.activeElement.tagName.toLowerCase() === "textarea";

        // Si el foco no está en un input, permite que se ejecute la acción de la tecla
        if (!isInputFocused && event.key.toLowerCase() === "q") {
          toggleMenu();
        }
      });

      // Detectar el toque en pantalla (para dispositivos móviles)
      document.addEventListener("touchstart", function (event) {
        startX = event.touches[0].clientX;  // Posición inicial del toque
      });

      document.addEventListener("touchend", function (event) {
        const endX = event.changedTouches[0].clientX;  // Posición final del toque
        if (startX - endX > 50) {
          // Toque de derecha a izquierda
          toggleMenu();
        } else if (endX - startX > 50) {
          // Toque de izquierda a derecha
          toggleMenu();
        }
      });
    </script>


    <script>
      async function remove_button_from_grid(row, col) {
        const folder_data = window.folder_data;
        const folder_name = window.folder_name;

        // Buscar el índice del botón que coincida con la fila y columna proporcionadas
        const buttonIndex = folder_data.buttons.findIndex(button => button.row == row && button.column == col);

        // Si encontramos el botón, lo eliminamos
        if (buttonIndex !== -1) {
          folder_data.buttons.splice(buttonIndex, 1);  // Eliminar el botón
          console.log(`Button at row ${row}, column ${col} removed.`);

          // Esperamos a que la función de subida termine
          result = await uploadFolderData(folder_name, folder_data);
          updateGrid(result.folder)



        } else {
          console.log(`No button found at row ${row}, column ${col}.`);
        }
      }
    </script>

    <script>
      const translations = {{ context["text"] | tojson | safe }};
      function getTranslation(key) {

        return translations[key] || key;
      }
    </script>

    <script>
      function search_commands(search) {

        const containers = document.querySelectorAll("#menuContainer .container");
        const categories = document.querySelectorAll("#menuContainer [id^='category_']");
        const query = search.trim().toLowerCase();

        if (!query) {
          containers.forEach(container => {
            container.classList.add("hidden");
            container.querySelectorAll("button").forEach(button => button.classList.remove("hidden"));
          });
          categories.forEach(category => category.classList.remove("hidden"));
          return;
        }

        containers.forEach(container => {
          const buttons = [...container.querySelectorAll("button")];
          const hasMatch = buttons.some(button => button.textContent.toLowerCase().includes(query));

          container.classList.toggle("hidden", !hasMatch);
          buttons.forEach(button => button.classList.toggle("hidden", !button.textContent.toLowerCase().includes(query)));
        });

        // Ocultar categorías si no tienen botones visibles
        categories.forEach(category => {
          const containerId = category.id.replace("category_", "container_");
          const container = document.getElementById(containerId);
          const hasVisibleButtons = container && container.querySelector("button:not(.hidden)");

          category.classList.toggle("hidden", !hasVisibleButtons);
        });
      }
    </script>


    <script>
      function set_menu_commands(jsonData) {
        const container = document.getElementById("menuContainer");
        //add an input to search
        let search = document.createElement("input");
        search.placeholder = "Search something...";
        search.addEventListener("input", function () {
          search_commands(search.value);
        })
        container.appendChild(search);


        Object.entries(jsonData).forEach(([category, data]) => {
          let _category = category.replace(/ /g, "").replace("'", "").toUpperCase();
          let Q1 = _category + "_CATEGORY_NAME";
          let category_name = getTranslation(Q1);
          if (category_name == Q1) {
            category_name = category;
          }

          // create the category div
          const categoryDiv = document.createElement("div"); 1
          categoryDiv.id = "category_" + _category;
          container.appendChild(categoryDiv);

          //set title 
          let title = document.createElement("h2");
          title.textContent = category_name;


          //set category icon
          let icon = document.createElement("img");
          icon.src = "static/img/menu_icon_white.png";
          icon.style.width = "30px";
          icon.style.aspectRatio = "1";

          let title_container = document.createElement("div");

          //make a div to style the title
          title_container.classList.add("title_container");
          title_container.onclick = function () {
            toggleCategory(categoryDiv);
          };
          title_container.appendChild(icon);
          title_container.appendChild(title);

          categoryDiv.prepend(title_container);

          // create a container for all the buttons and subcats on the category
          const categ_container = document.createElement("div");
          categ_container.id = "container_" + _category;
          categ_container.classList.add("container", "hidden");
          categoryDiv.appendChild(categ_container);


          //iter trhough all the elements of each category
          Object.entries(data).forEach(([name, subdata]) => {
            // if the type is multiple, create a subcategory div
            if (subdata.TYPE === "multiple") {
              let _subcategory = _category + "_" + name.replace(/ /g, "_").replace("'", "").toLowerCase();
              let Q2 = _subcategory + "__category_name";
              let _subcat_desc = _subcategory + "__category_description";

              let subcat_name = getTranslation(Q2);
              let subcat_desc = getTranslation(_subcat_desc);

              if (subcat_name == Q2) {
                subcat_name = name;
              }
              const subcategoryDiv = document.createElement("div");
              const subcateg_container = document.createElement("div");

              //create a title container
              let subtitle_container = document.createElement("div");
              subtitle_container.classList.add("title_container");
              subtitle_container.onclick = function () {
                toggleCategory(subcategoryDiv);
              }

              let icon = document.createElement("img");
              let subTitle = document.createElement("h3");
              icon.src = "static/img/menu_icon_white.png";
              icon.style.width = "30px";
              icon.style.aspectRatio = "1";

              subtitle_container.appendChild(icon);
              subtitle_container.appendChild(subTitle);


              subTitle.textContent = subcat_name;

              subcategoryDiv.prepend(subtitle_container);


              subcateg_container.classList.add("container", "hidden");
              subcategoryDiv.appendChild(subcateg_container);
              categ_container.appendChild(subcategoryDiv);

              Object.entries(subdata.commands).forEach(([index, button_data]) => {
                button_data.inputs.forEach((input, inp_index) => input.label = getTranslation(`${_subcategory ? _subcategory : _category}_${index}_input${inp_index}`));


                addButton(subcateg_container, index, button_data, _category, _subcategory);

              })

            } else {
              //this are buttons of a category
              subdata.inputs.forEach((input, inp_index) => input.label = getTranslation(`${_category}_${name.replace(/ /g, "_").replace("'", "").toLowerCase()}_input${inp_index}`));
              addButton(categ_container, name, subdata, _category);
            }
          });
        });
      }


      function addButton(parentElement, name, data, categ = "", subcateg = "") {
        var button = document.createElement("button");
        //check if name is an integer, and not a string
        if (Number.isInteger(Number(name))) {

          query = subcateg + "_sub" + (Number(name) + 1) + "__btn_name"
          button.innerText = getTranslation(query);
        }
        else {
          query = categ + "_" + name.replace(/ /g, "_").replace("'", "").toLowerCase() + "__btn_name";
          button.innerText = getTranslation(query);
        }
        button.id = query
        window.buttonData[button.id] = data

        button.draggable = true;

        parentElement.appendChild(button);
      }

    </script>


    <script>
      //scrupt to show the menu contents
      function toggleCategory(menu) {
        //grab the div class container on the menu div
        container = menu.querySelector(".container");
        container.classList.toggle("hidden");

      }
    </script>

    <script>function setupDragAndDrop() {
        document.addEventListener("dragover", (event) => event.preventDefault());

        // Obtener los botones del menú
        const buttons = document.getElementById('menuContainer').querySelectorAll('button');
        const deck_buttons = document.querySelector(".buttons-container").querySelectorAll('div:empty');

        const buttonIds = new Set([...buttons].map(button => button.id)); // Crear un set con los IDs de los botones permitidos

        // Configurar el evento de dragstart para los botones
        buttons.forEach(button => {
          button.addEventListener('dragstart', (event) => {
            event.dataTransfer.setData("text", event.target.id);
          });
        });

        // Configurar el evento de drop para los elementos vacíos (donde se puede soltar)
        deck_buttons.forEach(deck => {
          deck.addEventListener('drop', (event) => {
            event.preventDefault();

            const draggedButtonId = event.dataTransfer.getData("text");

            // Verificar si el ID pertenece a los botones permitidos
            if (!buttonIds.has(draggedButtonId)) {
              return;
            }

            const draggedButton = document.getElementById(draggedButtonId);
            const parent = deck.parentNode;
            const gridStyle = window.getComputedStyle(parent);
            const gridColumns = gridStyle.getPropertyValue('grid-template-columns').split(' ');
            const gridRows = gridStyle.getPropertyValue('grid-template-rows').split(' ');

            const deckRect = deck.getBoundingClientRect();
            const parentRect = parent.getBoundingClientRect();

            const columnWidth = parseFloat(gridColumns[0].replace('px', ''));
            const rowHeight = parseFloat(gridRows[0].replace('px', ''));

            const offsetX = deckRect.left - parentRect.left;
            const offsetY = deckRect.top - parentRect.top;

            const column = Math.floor(offsetX / columnWidth) + 1;
            const row = Math.floor(offsetY / rowHeight) + 1;

            let current_button_data = window.buttonData[draggedButtonId];

            generate_button(current_button_data, window.folder_name, window.folder_data, column, row);
          });
        });
      }
      window.onload = setupDragAndDrop;
    </script>

    <script>
      let isFetching = false;
      const data = new Set();

      function Initialize_monitors(track) {
        // Agregar el track si aún no está en el set
        if (track) {
          data.add(track);
        }
        if (isFetching) return;
        isFetching = true;
        fetch_monitors();
      }

      function fetch_monitors() {
        fetch('/monitors', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ track: [...data] }) // Convertir Set a Array antes de enviar
        })
          .then(response => response.json())
          .then(data => {
            window.usage_dict = data;
          })
          .catch(() => console.error("Error fetching usage data"))
          .finally(() => {
            update_monitors();
            setTimeout(fetch_monitors, 5000);
          });
      }

      function update_monitors() {
        console.log(window.usage_dict);
        var monitors = document.querySelectorAll('[data_from]');
        monitors.forEach(monitor => {
          const dataFrom = monitor.getAttribute('data_from');
          const value = dataFrom.split(".").reduce((obj, key) => obj && obj[key], window);
          if (value === undefined) return;
          monitor.innerHTML = value;
        });
      }
    </script>


</body>

</html>