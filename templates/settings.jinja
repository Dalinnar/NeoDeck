<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeoDeck settings</title>
    <link rel="icon" href="static\icons\icon.ico" />

    <script src="/static/js/selectionmenu.js"></script>
    <link rel="stylesheet" href="/static/css/settings.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
</head>

<body>


    <nav class="section_container">
        <a href="/"> go back</a>
    </nav>
    <div class="settings_container"></div>

</body>

<script>
    const translations = {{ context["text"] | tojson | safe }};
    function getTranslation(key) {
        return translations[key] || key;
    }
</script>

<script>
    const default_settings = {{ context['default_settings'] | tojson | safe }};
    const saved_settings = {{ context['saved_settings'] | tojson }};


    const section_container = document.querySelector('.section_container');

    // Crear un objeto para guardar los valores originales cuando se cargue una configuración
    let original_values = {};
    let currentCategory = null;

    //append a div h2  for each setting
    for (const categ in default_settings) {
        //check if categ is empty
        if (Object.keys(default_settings[categ]).length === 0) {
            continue;
        }

        const div = document.createElement('div');
        const h2 = document.createElement('h2');
        const key = categ.replace(/[\s\-]+/g, "_").toUpperCase() + "_CATEGORY_NAME";
        h2.textContent = getTranslation(key);
        h2.onclick = () => save_settings(categ);
        div.appendChild(h2);
        section_container.appendChild(div);
    }

    function save_settings(categ) {
        let prefixes = ["#", "_"]
        currentCategory = categ;
        const settings_container = document.querySelector('.settings_container');
        settings_container.innerHTML = '';

        const settings = default_settings[categ];
        const saved = saved_settings[categ] || {};

        // Guardar los valores originales cuando se carga una categoría
        original_values[categ] = { ...saved };

        Object.entries(settings).forEach(([setting, value]) => {

            let saved_value = saved[setting] ?? value;
            if (prefixes.some(prefix => setting.startsWith(prefix))) {
                saved_value = saved[setting.slice(1)] ?? value;
            }

            const div = document.createElement('div');
            div.classList.add('setting-item');




            // Crear input separado
            const [input, label] = createSettingInput(setting, value, saved_value);

            // Ajustes especiales para booleanos (checkbox)
            if (typeof value === 'boolean') {
                Object.assign(div.style, { flexDirection: "row-reverse", alignItems: "center" });
            }
            //if label is null
            div.append(...[label, input].filter(Boolean));


            settings_container.appendChild(div);

            // Inicializar multiselect si es necesario
            if (Array.isArray(value)) {
                multiselect(input.id);
            }
        });

        // Añadir el botón de "Restablecer"
        const reset_button = document.querySelector('#reset_button');
        if (reset_button) reset_button.onclick = () => resetSettings(categ);
    }


    function createSettingInput(setting, value, saved_value) {
        let input;
        let label = null;
        let secret = false;

        // Si es un "comando", devolver solo el botón/enlace (sin label)
        if (setting.startsWith('#')) {
            const text = setting.slice(1);
            const link = document.createElement('a');
            link.classList.add('setting-text');
            link.href = value;
            link.target = '_blank';
            link.textContent = getTranslation("label__" + text);
            return [link, null];
        }
        if (setting.startsWith('$')) {
            const endpoint = value;  // e.g. "/obs/status"
            const statusId = setting.slice(1); // e.g. "obs_status"

            const wrapper = document.createElement('div');
            wrapper.classList.add('status-check-item');

            const dot = document.createElement('span');
            dot.classList.add('status-dot', 'status-unknown');
            dot.id = `status-dot-${statusId}`;

            const msg = document.createElement('span');
            msg.classList.add('status-msg');
            msg.textContent = '...';

            const btn = document.createElement('button');
            btn.textContent = '↺';
            btn.title = 'Recheck';
            btn.onclick = () => fetchStatus(endpoint, dot, msg);

            wrapper.append(dot, msg, btn);

            // Auto-check on load
            fetchStatus(endpoint, dot, msg);

            return [wrapper, null];
        }
        if (setting.startsWith('_')) {
            secret = true;
            setting = setting.slice(1);
        }



        // Crear input según el tipo
        if (typeof value === 'boolean') {
            input = document.createElement('input');
            input.classList.add('custom-checkbox');
            input.type = 'checkbox';
            input.checked = saved_value;
        } else if (Array.isArray(value)) {
            input = document.createElement('select');
            input.multiple = true;
            [...new Set(saved_value)].forEach(val => {
                const opt = document.createElement('option');
                opt.value = opt.textContent = val;
                input.appendChild(opt);
            });
        } else if (typeof value === 'object' && value !== null) {
            input = document.createElement('select');
            Object.entries(value).forEach(([key, val]) => {
                const opt = document.createElement('option');
                opt.value = opt.textContent = val;
                opt.selected = saved_value === val;
                input.appendChild(opt);
            });
        } else {
            input = document.createElement('input');
            if (secret) {
                input.classList.add('secret');
            }
            input.type = 'text';
            input.value = saved_value;
        }

        // Crear label solo si no es un "comando"
        label = document.createElement('label');
        label.htmlFor = setting;
        label.textContent = getTranslation("label__" + setting);

        input.id = setting;
        input.name = setting;
        input.addEventListener('change', () => markChanged());

        return [input, label];
    }

    function markChanged() {
        const save_button = document.querySelector('#save_button');
        save_button.disabled = false; // Habilitar el botón de guardar cuando haya cambios
    }

    // Función para restablecer a los valores originales
    function resetSettings(categ) {
        const settings_container = document.querySelector('.settings_container');
        const inputs = settings_container.querySelectorAll('.setting-item input, .setting-item select');

        inputs.forEach(input => {
            const setting = input.id;
            const defaultValue = original_values[categ][setting];

            if (input.type === 'checkbox') {
                input.checked = defaultValue !== undefined ? defaultValue : false;
            } else if (input.tagName === 'SELECT') {
                input.value = defaultValue !== undefined ? defaultValue : '';
            } else {
                input.value = defaultValue !== undefined ? defaultValue : '';
            }
            //if input is a list and multiple
            if (Array.isArray(defaultValue) && input.multiple) {
                multiselect(input.id);
            }
        });

        // Deshabilitar el botón de guardar después de restablecer
        const save_button = document.querySelector('#save_button');
        save_button.disabled = true;
    }

    // Función dummy para "Guardar"
    function saveSettings() {
        const settings_container = document.querySelector('.settings_container');
        const inputs = settings_container.querySelectorAll('.setting-item input, .setting-item select');

        let updatedSettings = {};

        inputs.forEach(input => {
            const setting = input.id;
            let value;

            // Obtener el valor del input dependiendo del tipo
            if (input.type === 'checkbox') {
                value = input.checked;
            } else if (input.tagName === 'SELECT') {
                if (input.multiple) {
                    value = [];
                    for (let i = 0; i < input.options.length; i++) {
                        value.push(input.options[i].value);
                    }

                }
                else {
                    value = input.value;
                }
            } else {
                value = input.value;
            }

            // Agregar el valor actualizado al objeto de configuración
            updatedSettings[setting] = value;
        });

        // Preparar los datos para enviarlos al servidor
        const data = {
            [currentCategory]: updatedSettings// La categoría que está siendo editada
        };
        console.log(currentCategory)
        console.log("data: ", data);

        // Enviar los cambios al servidor

        fetch('/save_settings', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data),
        })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    console.log('Cambios guardados correctamente');
                    // Hacer algo después de que se haya guardado correctamente, como deshabilitar el botón
                    const save_button = document.querySelector('#save_button');
                    save_button.disabled = true;
                    //reload the page
                    location.reload();

                } else {
                    console.error('Hubo un error al guardar los cambios');
                }
            })
            .catch(error => {
                console.error('Error al guardar los cambios:', error);
            });

    }

    // Añadir la funcionalidad de los botones de Guardar y Restablecer al cargar la página
    document.addEventListener('DOMContentLoaded', () => {
        // Crear el contenedor de botones
        const settings_save_container = document.createElement('div');
        settings_save_container.classList.add('settings-buttons-container');

        // Crear los botones de "Restablecer" y "Guardar"
        const reset_button = document.createElement('button');
        const save_button = document.createElement('button');

        // Asignar texto a los botones usando traducciones
        reset_button.textContent = getTranslation('reset');
        reset_button.id = 'reset_button';
        save_button.disabled = true; // Deshabilitar el botón al inicio
        save_button.id = 'save_button';
        save_button.textContent = getTranslation('save');
        save_button.onclick = saveSettings;

        // Añadir los botones al contenedor
        settings_save_container.appendChild(reset_button);
        settings_save_container.appendChild(save_button);

        // Asegurarse de que body esté disponible
        const body = document.querySelector('body');
        if (body) {
            body.appendChild(settings_save_container);
        } else {
            console.error("No se pudo encontrar el body.");
        }
    });

    async function fetchStatus(endpoint, dot, msg) {
        dot.className = 'status-dot status-connecting';
        msg.textContent = '...';

        try {
            const res = await fetch(endpoint);
            if (res.ok) {
                dot.className = 'status-dot status-ok';
                msg.textContent = getTranslation('status_connected') || 'Connected';
            } else {
                dot.className = 'status-dot status-error';
                msg.textContent = `${getTranslation('status_error') || 'Error'} (${res.status})`;
            }
        } catch {
            dot.className = 'status-dot status-error';
            msg.textContent = getTranslation('status_unreachable') || 'Unreachable';
        }
    }
</script>


</html>